import sys
import random
import pygame

pygame.init()

taille_fenetre = (1300, 800)
ecran = pygame.display.set_mode(taille_fenetre)
pygame.display.set_caption("Crazy Racer")

BLANC = pygame.Color("white")
NOIR = pygame.Color("black")
GRIS = pygame.Color("gray25")
JAUNE = pygame.Color("gold")

COULEURS_VOITURE = [
    pygame.Color("red"), pygame.Color("orange"), pygame.Color("yellow"),
    pygame.Color("green"), pygame.Color("cyan"), pygame.Color("blue"),
    pygame.Color("purple"), pygame.Color("pink"),
    pygame.Color("white"), pygame.Color("brown"),
]
couleur_index = 0

police_titre = pygame.font.SysFont(None, 110)
police_texte = pygame.font.SysFont(None, 40)

ACCUEIL, JEU, FIN, PAUSE = 0, 1, 2, 3
etat = ACCUEIL

route = pygame.Rect(350, 0, 600, 800)
nb_voies = 4
largeur_voie = route.width // nb_voies
centres_voies = [
    route.left + largeur_voie // 2 + i * largeur_voie
    for i in range(nb_voies)
]

largeur_voiture_max = int(largeur_voie * 0.6)
hauteur_voiture_max = int(largeur_voiture_max * 1.6)

image_voiture_originale = pygame.image.load("voiture_nsi.png").convert_alpha()
w, h = image_voiture_originale.get_size()
facteur = min(largeur_voiture_max / w, hauteur_voiture_max / h)
image_voiture = pygame.transform.smoothscale(
    image_voiture_originale, (int(w * facteur), int(h * facteur))
)
voiture = image_voiture.get_rect()
voiture.centerx = centres_voies[1]
voiture.bottom = taille_fenetre[1] - 30  # ✅ en bas

image_adverse_originale = pygame.image.load("voiture_adverse_nsi.png").convert_alpha()
wa, ha = image_adverse_originale.get_size()
facteur_adverse = min(largeur_voiture_max / wa, hauteur_voiture_max / ha)
image_voiture_adverse = pygame.transform.smoothscale(
    image_adverse_originale, (int(wa * facteur_adverse), int(ha * facteur_adverse))
)

image_bouclier = pygame.image.load("bouclier_nsi.png").convert_alpha()
wb, hb = image_bouclier.get_size()
largeur_bouclier_max = int(largeur_voie * 0.5)
hauteur_bouclier_max = int(largeur_bouclier_max * 0.75)
facteur_bouclier = min(largeur_bouclier_max / wb, hauteur_bouclier_max / hb)
image_bouclier = pygame.transform.smoothscale(
    image_bouclier, (int(wb * facteur_bouclier), int(hb * facteur_bouclier))
)

image_mer_originale = pygame.image.load("mer_nsi.png").convert()
largeur_mer_gauche = route.left
largeur_mer_droite = taille_fenetre[0] - route.right
image_mer_gauche = pygame.transform.scale(image_mer_originale, (largeur_mer_gauche, taille_fenetre[1]))
image_mer_droite = pygame.transform.scale(image_mer_originale, (largeur_mer_droite, taille_fenetre[1]))
taille_mer = image_mer_gauche.get_height()

vitesse_laterale = 4
voitures_adverses = []
powerups = []

vitesse_scroll = 4
vitesse_cible = 4
acceleration = 0.07
vitesse_max = 10
vitesse_min = 3

distance = 0
score = 0

delai_spawn_base = 120
compteur_spawn = 0
dernieres_voies = []

delai_powerup = 350
compteur_powerup = 0

bouclier = False
temps_bouclier = 0
DUREE_BOUCLIER = 5000

bouton_jouer = pygame.Rect(525, 460, 250, 90)

clock = pygame.time.Clock()
en_cours = True

mer_offset = 0
route_offset = 0


def reset_partie():
    global voitures_adverses, powerups, vitesse_scroll, vitesse_cible, distance, score, bouclier, dernieres_voies
    voitures_adverses.clear()
    powerups.clear()
    dernieres_voies.clear()
    vitesse_scroll = 4
    vitesse_cible = 4
    distance = 0
    score = 0
    bouclier = False
    voiture.centerx = centres_voies[1]
    voiture.bottom = taille_fenetre[1] - 30


def voie_disponible():
    voies = list(range(nb_voies))
    for v in dernieres_voies:
        if v in voies:
            voies.remove(v)
    return random.choice(voies if voies else list(range(nb_voies)))


while en_cours:
    dt = clock.tick(60)

    for e in pygame.event.get():
        if e.type == pygame.QUIT:
            en_cours = False

        if e.type == pygame.MOUSEBUTTONDOWN:
            if etat == ACCUEIL and bouton_jouer.collidepoint(e.pos):
                etat = JEU
                reset_partie()

        if e.type == pygame.KEYDOWN:
            if etat == JEU and e.key == pygame.K_ESCAPE:
                etat = PAUSE
            elif etat == PAUSE and e.key == pygame.K_ESCAPE:
                etat = JEU

            if etat == FIN and e.key == pygame.K_RETURN:
                etat = JEU
                reset_partie()

            if e.key == pygame.K_z:
                etat = ACCUEIL
            if e.key == pygame.K_a:
                en_cours = False

    touches = pygame.key.get_pressed()

    if etat == JEU:
        if touches[pygame.K_UP]:
            vitesse_cible = min(vitesse_cible + 0.12, vitesse_max)
        elif touches[pygame.K_DOWN]:
            vitesse_cible = max(vitesse_cible - 0.12, vitesse_min)

        vitesse_scroll += (vitesse_cible - vitesse_scroll) * acceleration

        mer_offset = (mer_offset + vitesse_scroll) % taille_mer
        route_offset = (route_offset + vitesse_scroll * 1.5) % 40  # ✅ route plus rapide

        # ✅ distance réaliste (~2.5 m voiture)
        distance += vitesse_scroll * 0.05
        score = int(distance)

        if touches[pygame.K_LEFT]:
            voiture.x -= vitesse_laterale
        if touches[pygame.K_RIGHT]:
            voiture.x += vitesse_laterale

        voiture.left = max(voiture.left, route.left)
        voiture.right = min(voiture.right, route.right)

        # ✅ difficulté très progressive
        delai_spawn = max(50, delai_spawn_base - int(distance / 200))

        compteur_spawn += 1
        if compteur_spawn >= delai_spawn:
            voie = voie_disponible()
            dernieres_voies.append(voie)
            if len(dernieres_voies) > 2:
                dernieres_voies.pop(0)

            rect = image_voiture_adverse.get_rect()
            rect.centerx = centres_voies[voie]
            rect.bottom = 0
            voitures_adverses.append(rect)
            compteur_spawn = 0

        compteur_powerup += 1
        if compteur_powerup >= delai_powerup:
            voie = voie_disponible()
            rect = image_bouclier.get_rect()
            rect.centerx = centres_voies[voie]
            rect.bottom = 0
            powerups.append(rect)
            compteur_powerup = 0

        for v in voitures_adverses[:]:
            v.y += vitesse_scroll * 0.7  # ✅ plus lent que route
            if v.top > taille_fenetre[1]:
                voitures_adverses.remove(v)
            if voiture.colliderect(v):
                if bouclier:
                    bouclier = False
                    voitures_adverses.remove(v)
                else:
                    etat = FIN

        for p in powerups[:]:
            p.y += vitesse_scroll
            if p.top > taille_fenetre[1]:
                powerups.remove(p)
            if voiture.colliderect(p):
                bouclier = True
                temps_bouclier = pygame.time.get_ticks()
                powerups.remove(p)

        if bouclier and pygame.time.get_ticks() - temps_bouclier > DUREE_BOUCLIER:
            bouclier = False

    if etat == ACCUEIL:
        ecran.fill(NOIR)
        ecran.blit(police_titre.render("CRAZY RACER", True, BLANC), (380, 200))
        ecran.blit(image_voiture, (630, 380))
        pygame.draw.rect(ecran, GRIS, bouton_jouer, border_radius=12)
        ecran.blit(police_texte.render("JOUER", True, BLANC),
                   (bouton_jouer.x + 75, bouton_jouer.y + 25))

    elif etat == JEU or etat == PAUSE:

        for y in range(-taille_mer, taille_fenetre[1] + taille_mer, taille_mer):
            ecran.blit(image_mer_gauche, (0, y + mer_offset))
            ecran.blit(image_mer_droite, (route.right, y + mer_offset))

        pygame.draw.rect(ecran, GRIS, route)

        for i in range(1, nb_voies):
            x = route.left + i * largeur_voie
            for y in range(-40, 800, 40):
                pygame.draw.rect(ecran, BLANC, (x - 2, y + route_offset, 4, 20))

        for v in voitures_adverses:
            ecran.blit(image_voiture_adverse, v.topleft)

        for p in powerups:
            ecran.blit(image_bouclier, p.topleft)

        ecran.blit(image_voiture, voiture.topleft)

        if bouclier:
            pygame.draw.rect(ecran, JAUNE, voiture.inflate(10, 10), 3)

        ecran.blit(police_texte.render(f"Vitesse : {int(vitesse_scroll * 10)}", True, BLANC), (950, 20))
        ecran.blit(police_texte.render(f"Distance : {int(distance)} m", True, BLANC), (950, 60))
        ecran.blit(police_texte.render(f"Score : {score}", True, BLANC), (950, 100))

        if etat == PAUSE:
            ecran.blit(police_titre.render("PAUSE", True, BLANC), (520, 300))

    elif etat == FIN:
        ecran.fill(NOIR)
        ecran.blit(police_titre.render("COURSE TERMINÉE", True, BLANC), (330, 300))
        ecran.blit(police_texte.render(f"Score : {score}", True, BLANC), (500, 400))
        ecran.blit(police_texte.render("Entrée : recommencer", True, BLANC), (430, 450))
        ecran.blit(police_texte.render("Z : menu   A : quitter", True, BLANC), (430, 490))

    pygame.display.update()

pygame.quit()
sys.exit()
